<Window x:Class="ANEVRED.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:ANEVRED.Controls"
        mc:Ignorable="d"
        Title="ANEVRED Optimizer" Icon="Assets/AppIcon.ico" Height="820" Width="1440" MinHeight="700" MinWidth="1180" WindowState="Maximized">
    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="42"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="248"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="#06101A" BorderBrush="#122236" BorderThickness="0,0,0,1">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="218"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="{Binding AppLogoSource}" Width="34" Height="34" Margin="0,0,10,0" SnapsToDevicePixels="True" RenderOptions.BitmapScalingMode="HighQuality" Effect="{DynamicResource LogoContrastEffect}"/>
                    <TextBlock Text="ANEVRED" FontSize="23" FontWeight="SemiBold" Foreground="#F5FAFF"/>
                    <TextBlock Text=" OPTIMIZER" Foreground="#7CA0C8" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                </StackPanel>
                <ItemsControl Grid.Column="1" ItemsSource="{Binding NavigationItems}" VerticalAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource TopNavButtonStyle}" Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding Key}" Margin="2,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Title}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding CurrentProfile}" Width="180" Margin="0,0,16,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Grid.RowSpan="2" Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="0,0,1,0" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <Border Style="{StaticResource PanelCardStyle}" Padding="16">
                        <StackPanel>
                            <TextBlock Text="{Binding L[SystemStatus]}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock Text="{Binding PerformanceStateText}" FontSize="21" FontWeight="SemiBold" Foreground="{Binding PerformanceStateBrush}" Margin="0,10,0,2"/>
                            <TextBlock Text="{Binding L[PerformanceScore]}" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock Text="{Binding PerformanceScoreText, StringFormat={}{0}/100}" FontSize="18" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Grid.Row="1" Style="{StaticResource PanelCardStyle}" Padding="10">
                    <ItemsControl ItemsSource="{Binding NavigationItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding Key}" Margin="0,0,0,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}" Width="24" Foreground="{DynamicResource AccentBrush}"/>
                                        <TextBlock Text="{Binding Title}"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <StackPanel Grid.Row="2" Margin="8,12,8,4">
                    <TextBlock Text="{Binding L[Language]}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding SupportedLanguages}" DisplayMemberPath="DisplayName" SelectedValuePath="Code" SelectedValue="{Binding CurrentLanguage}" Margin="0,0,0,12"/>
                    <TextBlock Text="{Binding L[Theme]}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding ThemeMode}" Margin="0,0,0,14"/>
                    <TextBlock Text="v0.3.0" Foreground="{DynamicResource DisabledTextBrush}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Grid.Column="1" Margin="12">
            <Image Source="{Binding AppLogoSource}"
                   Width="760"
                   Height="760"
                   Opacity="{DynamicResource WorkspaceLogoOpacity}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   SnapsToDevicePixels="True"
                   Effect="{DynamicResource LogoContrastEffect}"/>
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Visibility="{Binding IsDashboardView, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding MetricCards}" Margin="0,0,0,8">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PanelCardStyle}" Width="166" Height="116" Margin="0,0,8,8" Padding="12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Row="1" Text="{Binding Value}" FontSize="21" FontWeight="SemiBold" Foreground="{Binding Accent}" Margin="0,4,0,0"/>
                                        <TextBlock Grid.Row="2" Text="{Binding Detail}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        <controls:HistoryGraphControl Grid.Row="3" Values="{Binding History}" MaxPoints="70" Stroke="{Binding Accent}" Fill="Transparent" Height="24" VerticalAlignment="Bottom"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*"/>
                            <ColumnDefinition Width="0.8*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource PanelCardStyle}" Margin="0,0,8,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="205"/>
                                </Grid.RowDefinitions>
                                <Grid>
                                    <TextBlock Text="{Binding L[PerformanceOverview]}" FontSize="16" FontWeight="SemiBold"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="CPU %" Foreground="{DynamicResource CpuAccentBrush}" Margin="0,0,14,0"/>
                                        <TextBlock Text="GPU %" Foreground="{DynamicResource GpuAccentBrush}" Margin="0,0,14,0"/>
                                        <TextBlock Text="RAM %" Foreground="{DynamicResource RamAccentBrush}" Margin="0,0,14,0"/>
                                        <TextBlock Text="VRAM %" Foreground="{DynamicResource VramAccentBrush}"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Grid.Row="1" Margin="0,16,0,0">
                                    <controls:HistoryGraphControl Values="{Binding CpuHistory}" MaxPoints="{Binding SelectedHistoryPoints}" Stroke="{DynamicResource CpuAccentBrush}" Fill="{DynamicResource GraphFillBrush}"/>
                                    <controls:HistoryGraphControl Values="{Binding RamHistory}" MaxPoints="{Binding SelectedHistoryPoints}" Stroke="{DynamicResource RamAccentBrush}" Fill="Transparent"/>
                                    <controls:HistoryGraphControl Values="{Binding GpuHistory}" MaxPoints="{Binding SelectedHistoryPoints}" Stroke="{DynamicResource GpuAccentBrush}" Fill="Transparent"/>
                                    <controls:HistoryGraphControl Values="{Binding VramHistory}" MaxPoints="{Binding SelectedHistoryPoints}" Stroke="{DynamicResource AccentBrush}" Fill="Transparent"/>
                                </Grid>
                            </Grid>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource PanelCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="205"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="{Binding L[FrametimeGraph]}" FontSize="16" FontWeight="SemiBold"/>
                                <controls:HistoryGraphControl Grid.Row="1" Values="{Binding FrametimeHistory}" MaxPoints="{Binding SelectedHistoryPoints}" Stroke="{DynamicResource FrametimeAccentBrush}" Fill="{DynamicResource GraphFillBrush}" Margin="0,12,0,0"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource PanelCardStyle}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="{Binding L[RamUsage]}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding RamGbText}" FontSize="18" Margin="0,12,0,6"/>
                                <ProgressBar Value="{Binding RamUsagePercent, Mode=OneWay}" Maximum="100"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource PanelCardStyle}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="{Binding L[VramUsage]}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding VramGbText}" FontSize="18" Margin="0,12,0,6"/>
                                <ProgressBar Value="{Binding VramUsagePercent, Mode=OneWay}" Maximum="100"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource PanelCardStyle}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="{Binding L[GpuLoad]}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding GpuUsageText}" FontSize="22" Foreground="{DynamicResource GpuAccentBrush}" Margin="0,12,0,6"/>
                                <TextBlock Text="{Binding L[WindowsCounter]}" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding L[PagefileUsage]}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding PagefileGbText}" FontSize="18" Margin="0,12,0,6"/>
                                <ProgressBar Value="{Binding PagefileUsagePercent, Mode=OneWay}" Maximum="100"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="0.8*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource PanelCardStyle}" Margin="0,0,8,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="220"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="{Binding L[TopProcesses]}" FontSize="16" FontWeight="SemiBold"/>
                                <DataGrid Grid.Row="1"
                                          x:Name="DashboardProcessesGrid"
                                          ItemsSource="{Binding Processes}"
                                          SelectedItem="{Binding SelectedProcess, Mode=TwoWay}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserSortColumns="True"
                                          Margin="0,12,0,0"
                                          PreviewMouseRightButtonDown="ProcessGridPreviewMouseRightButtonDown">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="{Binding PlacementTarget.DataContext.L[ProtectSelectedProcess], RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Command="{Binding PlacementTarget.DataContext.ProtectSelectedProcessCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="{Binding PlacementTarget.DataContext.L[OptimizeSelectedProcess], RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Command="{Binding PlacementTarget.DataContext.OptimizeSelectedProcessCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn x:Name="DashboardProcessColumn" Header="Process" Binding="{Binding Name}" Width="2*"/>
                                        <DataGridTextColumn Header="CPU %" Binding="{Binding CpuPercent, StringFormat={}{0:0.0}%}" Width="82"/>
                                        <DataGridTextColumn Header="GPU %" Binding="{Binding GpuPercent, StringFormat={}{0:0.0}%}" Width="82"/>
                                        <DataGridTextColumn Header="RAM" Binding="{Binding MemoryMb, StringFormat={}{0:0} MB}" Width="100"/>
                                        <DataGridTextColumn Header="Commit" Binding="{Binding CommitMb, StringFormat={}{0:0} MB}" Width="100"/>
                                        <DataGridTextColumn Header="VRAM" Binding="{Binding VramMb, StringFormat={}{0:0} MB}" Width="100"/>
                                        <DataGridTextColumn x:Name="DashboardPriorityColumn" Header="Priority" Binding="{Binding Priority}" Width="100"/>
                                        <DataGridTextColumn x:Name="DashboardAiScoreColumn" Header="AI" Binding="{Binding AiScore}" Width="60"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource PanelCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="220"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="{Binding L[CoreLoad]}" FontSize="16" FontWeight="SemiBold"/>
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding Cores}" Margin="0,12,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="2"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,12,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="58"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="44"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                <ProgressBar Grid.Column="1" Value="{Binding UsagePercent, Mode=OneWay}" Maximum="100" Margin="6,0"/>
                                                <TextBlock Grid.Column="2" Text="{Binding UsagePercent, StringFormat={}{0:0}%}" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Visibility="{Binding IsAiView, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border Style="{StaticResource PanelCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding L[AiRecommendations]}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16"/>
                        <ItemsControl ItemsSource="{Binding Recommendations}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource PanelAltBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Severity}" Foreground="{DynamicResource CpuAccentBrush}" Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding Explanation}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,8,0,0"/>
                                            <TextBlock Text="{Binding Evidence}" Foreground="{DynamicResource DisabledTextBrush}" Margin="0,6,0,10"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="{Binding ActionText}" Command="{Binding DataContext.ApplyRecommendationCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Margin="0,0,8,0"/>
                                                <Button Content="{Binding DataContext.L[Details], RelativeSource={RelativeSource AncestorType=Window}}" Command="{Binding DataContext.ShowRecommendationDetailsCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Margin="0,0,8,0"/>
                                                <Button Content="{Binding DataContext.L[Ignore], RelativeSource={RelativeSource AncestorType=Window}}" Command="{Binding DataContext.IgnoreRecommendationCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <Grid Visibility="{Binding IsProcessesView, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border Style="{StaticResource PanelCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding L[ProcessList]}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,14"/>
                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding L[ProcessSelection]}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SelectedProcessInfoText}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="{Binding L[ProtectSelectedProcess]}" Command="{Binding ProtectSelectedProcessCommand}" Margin="0,0,8,0"/>
                            <Button Grid.Column="2" Content="{Binding L[OptimizeSelectedProcess]}" Command="{Binding OptimizeSelectedProcessCommand}"/>
                        </Grid>
                        <DataGrid Grid.Row="2"
                                  x:Name="ProcessesGrid"
                                  ItemsSource="{Binding Processes}"
                                  SelectedItem="{Binding SelectedProcess, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserSortColumns="True"
                                  PreviewMouseRightButtonDown="ProcessGridPreviewMouseRightButtonDown">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{Binding PlacementTarget.DataContext.L[ProtectSelectedProcess], RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Command="{Binding PlacementTarget.DataContext.ProtectSelectedProcessCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="{Binding PlacementTarget.DataContext.L[OptimizeSelectedProcess], RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Command="{Binding PlacementTarget.DataContext.OptimizeSelectedProcessCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn x:Name="ProcessColumn" Binding="{Binding Name}" Width="2*"/>
                                <DataGridTextColumn x:Name="PidColumn" Binding="{Binding Id}" Width="72"/>
                                <DataGridTextColumn x:Name="ProcessCpuColumn" Binding="{Binding CpuPercent, StringFormat={}{0:0.0}%}" Width="86"/>
                                <DataGridTextColumn x:Name="ProcessGpuColumn" Binding="{Binding GpuPercent, StringFormat={}{0:0.0}%}" Width="86"/>
                                <DataGridTextColumn x:Name="ProcessRamColumn" Binding="{Binding MemoryMb, StringFormat={}{0:0} MB}" Width="105"/>
                                <DataGridTextColumn x:Name="ProcessCommitColumn" Binding="{Binding CommitMb, StringFormat={}{0:0} MB}" Width="105"/>
                                <DataGridTextColumn x:Name="ProcessVramColumn" Binding="{Binding VramMb, StringFormat={}{0:0} MB}" Width="105"/>
                                <DataGridTextColumn x:Name="PriorityColumn" Binding="{Binding Priority}" Width="110"/>
                                <DataGridCheckBoxColumn x:Name="ProtectedColumn" Binding="{Binding IsProtected, Mode=OneWay}" Width="88"/>
                                <DataGridTextColumn x:Name="AiScoreColumn" Binding="{Binding AiScore}" Width="80"/>
                                <DataGridTextColumn x:Name="StatusColumn" Binding="{Binding Status}" Width="120"/>
                                <DataGridTextColumn x:Name="WindowColumn" Binding="{Binding WindowTitle}" Width="1.5*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <ScrollViewer Visibility="{Binding IsGamingView, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <Border Style="{StaticResource PanelCardStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{Binding L[GamingMode]}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <Button Style="{StaticResource PrimaryButtonStyle}" Content="{Binding L[EnableGameMode]}" Command="{Binding EnableGameModeCommand}" Width="220" HorizontalAlignment="Left"/>
                            <TextBlock Text="{Binding L[PerformanceBudgetNote]}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{Binding L[SystemActions]}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <Button Content="{Binding L[OptimizeRamNow]}" Command="{Binding OptimizeMemoryCommand}" Margin="0,0,0,8"/>
                            <Button Content="{Binding L[OptimizeCpuNow]}" Command="{Binding OptimizeCpuCommand}" Margin="0,0,0,8"/>
                            <Button Content="{Binding L[OptimizeVramNow]}" Command="{Binding OptimizeVramCommand}" Margin="0,0,0,8"/>
                            <Button Content="{Binding L[StopUnnecessaryTasks]}" Command="{Binding StopUnnecessaryTasksCommand}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource PanelCardStyle}" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="{Binding L[MemoryCompressionExperimental]}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding L[MemoryCompressionExperimentalHint]}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,12"/>
                            <UniformGrid Columns="2">
                                <Button Content="{Binding L[MemoryCompressionOff]}" Command="{Binding DisableMemoryCompressionCommand}" Margin="0,0,8,0"/>
                                <Button Content="{Binding L[MemoryCompressionOn]}" Command="{Binding EnableMemoryCompressionCommand}"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Visibility="{Binding IsStarCitizenView, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <Border Style="{StaticResource PanelCardStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{Binding L[StarCitizenHub]}" FontSize="24" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding StarCitizenStatusText}" FontSize="18" Foreground="{DynamicResource RamAccentBrush}" Margin="0,10,0,0"/>
                            <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,0">
                                <Run Text="{Binding L[Session], Mode=OneWay}"/>
                                <Run Text=": "/>
                                <Run Text="{Binding SessionTimeText, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Text="{Binding StarCitizenRiskText}" FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource CpuAccentBrush}" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding ProtectedStatusText}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*"/>
                            <ColumnDefinition Width="0.9*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource PanelCardStyle}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="{Binding L[SessionOverview]}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding StarCitizenSessionSummaryText}" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <TextBlock Text="{Binding StarCitizenEventDeltaText}" Foreground="{DynamicResource AccentBrush}" Margin="0,10,0,0"/>
                                <TextBlock Text="{Binding LastSessionDisplayText}" Foreground="{DynamicResource DisabledTextBrush}" Margin="0,10,0,0"/>
                                <TextBlock Text="{Binding LastStarCitizenExitText}" Foreground="{DynamicResource CpuAccentBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding L[DefenderHintTitle]}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding DefenderHintText}" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    <Border Style="{StaticResource PanelCardStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{Binding L[MarkSessionEvent]}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <UniformGrid Columns="3">
                                <Button Content="{Binding L[MarkServerChange]}" Command="{Binding MarkServerChangeCommand}" Margin="0,0,8,0"/>
                                <Button Content="{Binding L[MarkRespawn]}" Command="{Binding MarkRespawnCommand}" Margin="0,0,8,0"/>
                                <Button Content="{Binding L[MarkStutter]}" Command="{Binding MarkStutterCommand}"/>
                            </UniformGrid>
                            <TextBlock Text="{Binding StarCitizenHotkeySummary}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*"/>
                            <ColumnDefinition Width="0.9*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource PanelCardStyle}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="{Binding L[MarkedEvents]}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <ItemsControl ItemsSource="{Binding StarCitizenEvents}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Type}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding SessionTime}" Foreground="{DynamicResource DisabledTextBrush}" FontSize="12"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding Summary}" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding L[ProtectedProcesses]}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <ItemsControl ItemsSource="{Binding ProtectedProcesses}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Priority}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding Status}" Foreground="{DynamicResource RamAccentBrush}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Visibility="{Binding IsHardwareView, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{Binding L[HardwareMonitor]}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <ItemsControl ItemsSource="{Binding MetricCards}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PanelCardStyle}" Width="220" Height="140" Margin="0,0,10,10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Value}" FontSize="28" FontWeight="SemiBold" Foreground="{Binding Accent}" Margin="0,8,0,0"/>
                                        <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <Grid Visibility="{Binding IsLogsView, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border Style="{StaticResource PanelCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding L[Logs]}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,14"/>
                        <DataGrid Grid.Row="1" x:Name="LogsGrid" ItemsSource="{Binding Logs}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn x:Name="LogTimeColumn" Binding="{Binding TimeText}" Width="86"/>
                                <DataGridTextColumn x:Name="LogLevelColumn" Binding="{Binding Level}" Width="80"/>
                                <DataGridTemplateColumn x:Name="LogMessageColumn" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Message}"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="None"
                                                       Padding="6,4"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <ScrollViewer Visibility="{Binding IsInfoView, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <Border Style="{StaticResource PanelCardStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="ANEVRED" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"/>
                            <TextBlock Text="{Binding L[AppExpansion]}" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding L[AppDescription]}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,12,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource PanelCardStyle}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="{Binding L[ToolDescription]}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <TextBlock Text="{Binding L[ToolDescriptionText]}" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                                <Separator Margin="0,16,0,16"/>
                                <TextBlock Text="{Binding L[SafetyNote]}" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding L[FooterNote]}" Foreground="{DynamicResource DisabledTextBrush}" TextWrapping="Wrap" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource PanelCardStyle}" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding L[LicensesAndNotices]}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <TextBlock Text="{Binding L[ChromeLicenseNotice]}" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding L[ChromePrivacyNotice]}" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,12,0,0"/>
                                <TextBlock Text="{Binding L[ThirdPartyNotice]}" Foreground="{DynamicResource DisabledTextBrush}" TextWrapping="Wrap" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Style="{StaticResource PanelCardStyle}" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="{Binding L[AiInfoTitle]}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <TextBlock Text="{Binding L[AiInfoText]}" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                            <Separator Margin="0,16,0,16"/>
                            <TextBlock Text="{Binding L[AiStorageTitle]}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding L[AiStorageText]}" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding L[AiReuseText]}" Foreground="{DynamicResource DisabledTextBrush}" TextWrapping="Wrap" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Visibility="{Binding IsSettingsView, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource PanelCardStyle}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="{Binding L[Settings]}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <CheckBox Content="{Binding L[AutoMode]}" IsChecked="{Binding Settings.AutoModeEnabled, Mode=TwoWay}" Margin="0,0,0,8"/>
                                <CheckBox Content="{Binding L[LocalLearning]}" IsChecked="{Binding Settings.LocalLearningEnabled, Mode=TwoWay}" Margin="0,0,0,8"/>
                                <CheckBox Content="{Binding L[PrivacyMaximum]}" IsChecked="{Binding Settings.PrivacyMaximumMode, Mode=TwoWay}" Margin="0,0,0,8"/>
                                <CheckBox Content="{Binding L[Autostart]}" IsChecked="{Binding Settings.StartWithWindows, Mode=TwoWay}" Margin="0,0,0,12"/>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="190"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="76"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding L[AutoRamRepeat]}" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="1" Maximum="60" Value="{Binding Settings.AutoRamIntervalMinutes, Mode=TwoWay}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding AutoRamIntervalText}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="190"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="76"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding L[AutoCpuRepeat]}" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="1" Maximum="60" Value="{Binding Settings.AutoCpuIntervalMinutes, Mode=TwoWay}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding AutoCpuIntervalText}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="190"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="76"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding L[RamThreshold]}" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="50" Maximum="98" Value="{Binding Settings.RamThresholdPercent, Mode=TwoWay}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding RamThresholdPercentText}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="190"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="76"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding L[CpuThreshold]}" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="50" Maximum="100" Value="{Binding Settings.CpuThresholdPercent, Mode=TwoWay}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding CpuThresholdPercentText}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="190"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="76"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding L[ProcessRefresh]}" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="3" Maximum="30" Value="{Binding Settings.ProcessRefreshSeconds, Mode=TwoWay}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ProcessRefreshSecondsText}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="190"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="76"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding L[MaxProcesses]}" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="50" Maximum="300" Value="{Binding Settings.MaxDisplayedProcesses, Mode=TwoWay}" TickFrequency="10" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding MaxDisplayedProcessesText}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource PanelCardStyle}" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding L[StarCitizenSettings]}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <TextBlock Text="{Binding L[StarCitizenPath]}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding StarCitizenLogPathText}" VerticalAlignment="Center" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <Button Grid.Column="1" Content="{Binding L[ChooseFolder]}" Click="BrowseStarCitizenPathClick"/>
                                </Grid>
                                <CheckBox Content="{Binding L[EnableHotkeys]}" IsChecked="{Binding Settings.StarCitizenHotkeysEnabled, Mode=TwoWay}" Margin="0,0,0,12"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding L[MarkServerChange]}" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Settings.StarCitizenServerChangeHotkey}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <Button Grid.Column="2" Content="{Binding L[PressHotkeyButton]}" Tag="ServerChange" Click="CaptureHotkeyButtonClick"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding L[MarkRespawn]}" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Settings.StarCitizenRespawnHotkey}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <Button Grid.Column="2" Content="{Binding L[PressHotkeyButton]}" Tag="Respawn" Click="CaptureHotkeyButtonClick"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding L[MarkStutter]}" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Settings.StarCitizenStutterHotkey}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <Button Grid.Column="2" Content="{Binding L[PressHotkeyButton]}" Tag="Stutter" Click="CaptureHotkeyButtonClick"/>
                                </Grid>
                                <TextBlock Text="{Binding L[HotkeyFormatHint]}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding HotkeyStatusText}" Foreground="{DynamicResource AccentBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                <Separator Margin="0,12,0,12"/>
                                <TextBlock Text="{Binding L[ScreenTranslation]}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <CheckBox Content="{Binding L[ScreenTranslationEnabled]}" IsChecked="{Binding Settings.ScreenTranslationEnabled, Mode=TwoWay}" Margin="0,0,0,8"/>
                                <CheckBox Content="{Binding L[ScreenTranslationAutoRefresh]}" IsChecked="{Binding Settings.ScreenTranslationAutoRefresh, Mode=TwoWay}" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding L[TranslationProviderChromeSelected]}" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding L[ScreenTranslationHotkey]}" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Settings.ScreenTranslationHotkey}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <Button Grid.Column="2" Content="{Binding L[PressHotkeyButton]}" Tag="Translation" Click="CaptureHotkeyButtonClick"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding L[ScreenTranslationCaptureHotkey]}" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Settings.ScreenTranslationCaptureHotkey}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <Button Grid.Column="2" Content="{Binding L[PressHotkeyButton]}" Tag="TranslationCapture" Click="CaptureHotkeyButtonClick"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding L[ScreenTranslationRegionHotkey]}" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Settings.ScreenTranslationRegionHotkey}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <Button Grid.Column="2" Content="{Binding L[PressHotkeyButton]}" Tag="TranslationRegion" Click="CaptureHotkeyButtonClick"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding L[TargetLanguage]}" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <ComboBox Grid.Column="1" SelectedValue="{Binding Settings.ScreenTranslationTargetLanguage, Mode=TwoWay}" SelectedValuePath="Tag" Margin="0,0,8,0">
                                        <ComboBoxItem Content="Deutsch" Tag="de"/>
                                        <ComboBoxItem Content="English" Tag="en"/>
                                        <ComboBoxItem Content="Russian" Tag="ru"/>
                                    </ComboBox>
                                    <Button Grid.Column="2" Content="{Binding L[ChooseScreenRegion]}" Click="ChooseTranslationRegionClick"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="{Binding L[TranslateNow]}" Click="CaptureScreenTranslationClick" MinWidth="150" Margin="0,0,8,0"/>
                                    <Button Content="{Binding L[CheckChromeTranslation]}" Click="CheckChromeTranslationClick" MinWidth="150"/>
                                </StackPanel>
                                <TextBlock Text="{Binding L[ChromePrivacyNotice]}" Foreground="{DynamicResource CpuAccentBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding L[ScreenTranslationHint]}" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    <Border Style="{StaticResource PanelCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="220"/>
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding NewProtectionPattern, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                                <Button Grid.Column="1" Content="{Binding L[AddRule]}" Command="{Binding AddProtectionRuleCommand}" Margin="0,0,8,0"/>
                                <Button Grid.Column="2" Content="{Binding L[RemoveRule]}" Command="{Binding RemoveProtectionRuleCommand}"/>
                            </Grid>
                            <DataGrid Grid.Row="1" x:Name="ProtectionGrid" ItemsSource="{Binding Settings.ProtectionRules}" SelectedItem="{Binding SelectedProtectionRule}" AutoGenerateColumns="False" CanUserAddRows="False" Margin="0,12,0,0">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn x:Name="RuleEnabledColumn" Binding="{Binding Enabled, Mode=TwoWay}" Width="76"/>
                                    <DataGridTextColumn x:Name="RulePatternColumn" Binding="{Binding Pattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                                    <DataGridTextColumn x:Name="RuleNotesColumn" Binding="{Binding Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <ScrollViewer Grid.Row="1" Grid.Column="2" Padding="0,12,12,12" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border Style="{StaticResource PanelCardStyle}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="{Binding L[AiRecommendations]}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <ItemsControl ItemsSource="{Binding Recommendations}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Explanation}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Severity}" Foreground="{DynamicResource CpuAccentBrush}" FontSize="12" HorizontalAlignment="Right"/>
                                            <Button Content="{Binding ActionText}" Command="{Binding DataContext.ApplyRecommendationCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" MinHeight="24" Padding="8,2" Margin="0,4,0,0"/>
                                            <Button Content="{Binding DataContext.L[Details], RelativeSource={RelativeSource AncestorType=Window}}" Command="{Binding DataContext.ShowRecommendationDetailsCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" MinHeight="24" Padding="8,2" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource PanelCardStyle}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="{Binding L[ProtectedProcesses]}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <ItemsControl ItemsSource="{Binding ProtectedProcesses}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Status}" Foreground="{DynamicResource RamAccentBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource PanelCardStyle}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="{Binding L[SystemActions]}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <UniformGrid Columns="2">
                            <Button Content="{Binding L[OptimizeRamNow]}" Command="{Binding OptimizeMemoryCommand}" Margin="0,0,6,6"/>
                            <Button Content="{Binding L[OptimizeCpuNow]}" Command="{Binding OptimizeCpuCommand}" Margin="0,0,0,6"/>
                            <Button Content="{Binding L[OptimizeVramNow]}" Command="{Binding OptimizeVramCommand}" Margin="0,0,6,6"/>
                            <Button Content="{Binding L[EnableGameMode]}" Command="{Binding EnableGameModeCommand}" Margin="0,0,0,6"/>
                            <Button Content="{Binding L[StopUnnecessaryTasks]}" Command="{Binding StopUnnecessaryTasksCommand}" Margin="0,0,6,6"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource PanelCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding L[AutoOptimization]}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <CheckBox Content="{Binding L[AutoMode]}" IsChecked="{Binding Settings.AutoModeEnabled, Mode=TwoWay}" Margin="0,0,0,8"/>
                        <CheckBox Content="{Binding L[LocalLearning]}" IsChecked="{Binding Settings.LocalLearningEnabled, Mode=TwoWay}" Margin="0,0,0,8"/>
                        <TextBlock Foreground="{DynamicResource SecondaryTextBrush}">
                            <Run Text="{Binding L[Auto], Mode=OneWay}"/>
                            <Run Text=": "/>
                            <Run Text="{Binding AutoOptimizationStatusText, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Foreground="{DynamicResource SecondaryTextBrush}">
                            <Run Text="{Binding L[Learning], Mode=OneWay}"/>
                            <Run Text=": "/>
                            <Run Text="{Binding LocalLearningStatusText, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding AutoRamIntervalText, StringFormat={}RAM: {0}}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,8,0,0"/>
                        <TextBlock Text="{Binding AutoCpuIntervalText, StringFormat={}CPU: {0}}" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="0,1,0,0" Padding="16,0">
            <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}">
                <Run Text="{Binding StarCitizenStatusText, Mode=OneWay}"/>
                <Run Text=" | "/>
                <Run Text="{Binding L[Session], Mode=OneWay}"/>
                <Run Text=" "/>
                <Run Text="{Binding SessionTimeText, Mode=OneWay}"/>
                <Run Text=" | "/>
                <Run Text="{Binding L[Profile], Mode=OneWay}"/>
                <Run Text=": "/>
                <Run Text="{Binding CurrentProfileText, Mode=OneWay}"/>
                <Run Text=" | VRAM: "/>
                <Run Text="{Binding VramPressureText, Mode=OneWay}"/>
                <Run Text=" | "/>
                <Run Text="{Binding ProtectedStatusText, Mode=OneWay}"/>
            </TextBlock>
        </Border>
    </Grid>
</Window>
