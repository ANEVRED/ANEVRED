<Window x:Class="ZestResourceOptimizer.RegionSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#55000000"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Cursor="Cross">
    <Canvas x:Name="Surface" Background="Transparent" MouseLeftButtonDown="SurfaceMouseLeftButtonDown" MouseMove="SurfaceMouseMove" MouseLeftButtonUp="SurfaceMouseLeftButtonUp" MouseRightButtonDown="SurfaceMouseRightButtonDown">
        <Rectangle x:Name="SelectionRectangle" Stroke="#90CAF9" StrokeThickness="2" Fill="#22007ACC" Visibility="Collapsed"/>
        <TextBlock Canvas.Left="20" Canvas.Top="20" Text="Linksklick halten und Bereich ziehen. Rechtsklick/Esc bricht ab." Foreground="White" FontSize="18" FontWeight="SemiBold"/>
    </Canvas>
</Window>
