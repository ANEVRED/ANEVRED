<Window x:Class="ZestResourceOptimizer.TranslationOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize">
    <Canvas>
        <Border x:Name="RegionFrame"
                BorderBrush="#77A5D8FF"
                BorderThickness="2"
                Background="#14000000"
                CornerRadius="6"/>
        <Border x:Name="TextPanel"
                BorderBrush="#88A5D8FF"
                BorderThickness="1"
                Background="#DD050A10"
                CornerRadius="6"
                Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <TextBlock x:Name="TranslationText"
                           TextWrapping="Wrap"
                           Foreground="White"
                           FontSize="15"
                           LineHeight="19"/>
            </ScrollViewer>
        </Border>
    </Canvas>
</Window>
